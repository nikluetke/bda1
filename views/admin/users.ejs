<%- include('../_header', { title: 'Admin – Users', user: null }) %>
<div class="admin-wrap">
  <div class="admin-header">
    <h1>User Management</h1>
    <span class="badge"><%= users.length %> user<%= users.length !== 1 ? 's' : '' %></span>
  </div>

  <% if (locals.query && query.error === 'self-delete') { %>
    <div class="alert error">You cannot delete your own account.</div>
  <% } %>

  <div class="table-wrap">
    <table class="admin-table">
      <thead>
        <tr>
          <th>Name</th>
          <th>Email</th>
          <th>Phone</th>
          <th>Admin</th>
          <th>Joined</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% users.forEach(u => { %>
        <tr class="<%= u.oid === currentOid ? 'row-self' : '' %>">
          <td><%= u.display_name || '—' %></td>
          <td><%= u.email || '—' %></td>
          <td><%= u.phone || '—' %></td>
          <td><% if (u.is_admin) { %><span class="tag admin">Admin</span><% } else { %>—<% } %></td>
          <td><%= new Date(u.created_at).toLocaleDateString() %></td>
          <td class="actions">
            <a href="/admin/users/<%= u.id %>/edit" class="btn sm">Edit</a>
            <% if (u.oid !== currentOid) { %>
              <form method="POST" action="/admin/users/<%= u.id %>/delete" class="inline-form"
                    onsubmit="return confirm('Delete <%= (u.display_name || u.email || 'this user').replace(/'/g, '') %>?')">
                <button type="submit" class="btn sm danger">Delete</button>
              </form>
            <% } %>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>
<%- include('../_footer') %>
