<%- include('../_header', { title: t.user_management }) %>
<div class="admin-wrap">
  <div class="admin-header">
    <h1><%= t.user_management %></h1>
    <span class="badge"><%= users.length %> <%= users.length !== 1 ? t.user_plural : t.user_singular %></span>
    <a href="/admin/duties" class="btn secondary sm" style="margin-left:auto"><%= t.all_duties %></a>
  </div>

  <% if (locals.query && query.error === 'self-delete') { %>
    <div class="alert error"><%= t.cannot_delete_self %></div>
  <% } %>

  <div class="table-wrap">
    <table class="admin-table">
      <thead>
        <tr>
          <th><%= t.col_name %></th>
          <th><%= t.col_email %></th>
          <th><%= t.col_phone %></th>
          <th><%= t.col_admin_flag %></th>
          <th><%= t.col_joined %></th>
          <th><%= t.col_actions %></th>
        </tr>
      </thead>
      <tbody>
        <% users.forEach(u => { %>
        <tr class="<%= u.oid === currentOid ? 'row-self' : '' %>">
          <td><%= u.display_name || '—' %></td>
          <td><%= u.email || '—' %></td>
          <td><%= u.phone || '—' %></td>
          <td><% if (u.is_admin) { %><span class="tag admin"><%= t.col_admin_flag %></span><% } else { %>—<% } %></td>
          <td><%= new Date(u.created_at).toLocaleDateString(t.date_locale) %></td>
          <td class="actions">
            <a href="/admin/users/<%= u.id %>/edit" class="btn sm"><%= t.btn_edit %></a>
            <% if (u.oid !== currentOid) { %>
              <form method="POST" action="/admin/users/<%= u.id %>/delete" class="inline-form"
                    onsubmit="return confirm('<%= t.confirm_delete %> <%= (u.display_name || u.email || '').replace(/'/g, '') %>?')">
                <button type="submit" class="btn sm danger"><%= t.btn_delete %></button>
              </form>
            <% } %>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>
<%- include('../_footer') %>
