<%- include('_header', { title: 'Edit Profile' }) %>
<div class="card">
  <h1>Edit Profile</h1>

  <% if (saved) { %>
    <div class="alert success">Phone number saved.</div>
  <% } %>
  <% if (error) { %>
    <div class="alert error"><%= error %></div>
  <% } %>

  <table class="info-table">
    <tr><th>Name</th>  <td><%= user.display_name || '—' %></td></tr>
    <tr><th>Email</th> <td><%= user.email || '—' %></td></tr>
  </table>

  <form method="POST" action="/profile" class="form">
    <label for="phone">Phone number</label>
    <input
      id="phone"
      name="phone"
      type="tel"
      maxlength="30"
      value="<%= user.phone || '' %>"
      placeholder="+1 555 000 0000"
    >
    <button type="submit" class="btn">Save</button>
  </form>
</div>
<%- include('_footer') %>
