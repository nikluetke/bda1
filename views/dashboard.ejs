<%- include('_header', { title: t.dashboard }) %>
<div class="card">
  <h1><%= t.dashboard %></h1>
  <table class="info-table">
    <tr>
      <th><%= t.label_name %></th>
      <td><%= user.display_name || '—' %></td>
    </tr>
    <tr>
      <th><%= t.label_email %></th>
      <td><%= user.email || '—' %></td>
    </tr>
    <tr>
      <th><%= t.label_phone %></th>
      <td><% if (user.phone) { %><%= user.phone %><% } else { %><em><%= t.not_set %></em><% } %></td>
    </tr>
    <tr>
      <th><%= t.label_member_since %></th>
      <td><%= new Date(user.created_at).toLocaleDateString(t.date_locale) %></td>
    </tr>
    <tr>
      <th><%= t.label_object_id %></th>
      <td><code style="font-size:.8rem;background:var(--code-bg);padding:.1rem .4rem;border-radius:4px"><%= user.oid %></code></td>
    </tr>
  </table>
  <a href="/profile" class="btn secondary"><%= t.edit_profile %></a>
</div>

<div class="card" style="margin-top:1.5rem">
  <h2 class="card-subheading"><%= t.upcoming_duties %></h2>
  <% if (upcomingDuties && upcomingDuties.length > 0) { %>
    <div class="upcoming-list">
      <% upcomingDuties.forEach(duty => { %>
        <%
          const dd = new Date(duty.duty_date + 'T00:00:00');
          const dayLabel = dd.toLocaleDateString(t.date_locale, { weekday: 'short', day: '2-digit', month: '2-digit' });
        %>
        <div class="upcoming-item">
          <span class="upcoming-day"><%= dayLabel %></span>
          <span class="upcoming-time"><%= duty.start_time %>&thinsp;&ndash;&thinsp;<%= duty.end_time %></span>
          <span class="upcoming-route"><%= duty.route %></span>
          <% if (duty.fleet_number) { %>
            <span class="upcoming-bus text-muted"><%= duty.fleet_number %></span>
          <% } %>
          <span class="upcoming-loc text-muted"><%= duty.start_location %> &rarr; <%= duty.end_location %></span>
        </div>
      <% }); %>
    </div>
    <a href="/duties" class="btn secondary" style="margin-top:1rem;font-size:.88rem"><%= t.view_full_schedule %></a>
  <% } else { %>
    <p class="text-muted" style="font-size:.9rem"><%= t.no_upcoming_duties %></p>
    <a href="/duties" class="btn secondary" style="margin-top:.75rem;font-size:.88rem"><%= t.view_duty_schedule %></a>
  <% } %>
</div>
<%- include('_footer') %>
