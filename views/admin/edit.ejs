<%- include('../_header', { title: 'Admin – Edit User', user: null }) %>
<div class="admin-wrap">
  <div class="admin-header">
    <a href="/admin" class="btn secondary sm">← Back</a>
    <h1>Edit User</h1>
  </div>

  <% if (saved) { %>
    <div class="alert success">Changes saved.</div>
  <% } %>
  <% if (error) { %>
    <div class="alert error"><%= error %></div>
  <% } %>

  <div class="card">
    <p class="meta">OID: <code><%= user.oid %></code> &nbsp;·&nbsp; ID: <%= user.id %></p>

    <form method="POST" action="/admin/users/<%= user.id %>/edit" class="form wide">
      <label for="display_name">Display name</label>
      <input id="display_name" name="display_name" type="text" maxlength="120"
             value="<%= user.display_name || '' %>">

      <label for="email">Email</label>
      <input id="email" name="email" type="email" maxlength="254"
             value="<%= user.email || '' %>">

      <label for="phone">Phone</label>
      <input id="phone" name="phone" type="tel" maxlength="30"
             value="<%= user.phone || '' %>" placeholder="+1 555 000 0000">

      <label for="driver_email">Assigned driver</label>
      <select id="driver_email" name="driver_email" class="form-select">
        <option value="">— not assigned —</option>
        <% driverEmails.forEach(de => { %>
          <option value="<%= de %>" <%= user.driver_email === de ? 'selected' : '' %>><%= de %></option>
        <% }); %>
      </select>

      <div class="checkbox-row">
        <input id="is_admin" name="is_admin" type="checkbox" value="on"
               <%= user.is_admin ? 'checked' : '' %>>
        <label for="is_admin">Administrator</label>
      </div>

      <button type="submit" class="btn">Save changes</button>
    </form>
  </div>
</div>
<%- include('../_footer') %>
