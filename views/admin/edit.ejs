<%- include('../_header', { title: t.heading_edit_user }) %>
<div class="admin-wrap">
  <div class="admin-header">
    <a href="/admin" class="btn secondary sm"><%= t.btn_back %></a>
    <h1><%= t.heading_edit_user %></h1>
  </div>

  <% if (saved) { %>
    <div class="alert success"><%= t.saved_success %></div>
  <% } %>
  <% if (errorKey) { %>
    <div class="alert error"><%= t[errorKey] %></div>
  <% } %>

  <div class="card">
    <p class="meta">OID: <code><%= user.oid %></code> &nbsp;·&nbsp; ID: <%= user.id %></p>

    <form method="POST" action="/admin/users/<%= user.id %>/edit" class="form wide">
      <label for="display_name"><%= t.label_display_name %></label>
      <input id="display_name" name="display_name" type="text" maxlength="120"
             value="<%= user.display_name || '' %>">

      <label for="email"><%= t.label_email %></label>
      <input id="email" name="email" type="email" maxlength="254"
             value="<%= user.email || '' %>">

      <label for="phone"><%= t.label_phone %></label>
      <input id="phone" name="phone" type="tel" maxlength="30"
             value="<%= user.phone || '' %>" placeholder="+49 151 000 0000">

      <label for="driver_email"><%= t.label_assigned_driver %></label>
      <select id="driver_email" name="driver_email" class="form-select">
        <option value=""><%= t.not_assigned %></option>
        <% driverEmails.forEach(de => { %>
          <option value="<%= de %>" <%= user.driver_email === de ? 'selected' : '' %>><%= de %></option>
        <% }); %>
      </select>

      <div class="checkbox-row">
        <input id="is_admin" name="is_admin" type="checkbox" value="on"
               <%= user.is_admin ? 'checked' : '' %>>
        <label for="is_admin"><%= t.label_is_admin %></label>
      </div>

      <button type="submit" class="btn"><%= t.btn_save_changes %></button>
    </form>
  </div>
</div>
<%- include('../_footer') %>
