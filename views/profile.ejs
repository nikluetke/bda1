<%- include('_header', { title: t.edit_profile }) %>
<div class="card">
  <h1><%= t.edit_profile %></h1>

  <% if (saved) { %>
    <div class="alert success"><%= t.phone_saved %></div>
  <% } %>
  <% if (errorKey) { %>
    <div class="alert error"><%= t[errorKey] %></div>
  <% } %>

  <table class="info-table">
    <tr><th><%= t.label_name %></th>  <td><%= user.display_name || '—' %></td></tr>
    <tr><th><%= t.label_email %></th> <td><%= user.email || '—' %></td></tr>
  </table>

  <form method="POST" action="/profile" class="form">
    <label for="phone"><%= t.phone_number %></label>
    <input
      id="phone"
      name="phone"
      type="tel"
      maxlength="30"
      value="<%= user.phone || '' %>"
      placeholder="+49 151 000 0000"
    >
    <button type="submit" class="btn"><%= t.save %></button>
  </form>
</div>
<%- include('_footer') %>
