<%- include('../_header', { title: t.all_duties }) %>
<div class="admin-wrap">
  <div class="admin-header">
    <h1><%= t.all_duties %></h1>
    <span class="badge"><%= duties.length %> <%= t.records %></span>
    <a href="/admin" class="btn secondary sm" style="margin-left:auto"><%= t.btn_back_users %></a>
  </div>

  <div class="table-wrap">
    <table class="admin-table">
      <thead>
        <tr>
          <th><%= t.col_date %></th>
          <th><%= t.col_driver %></th>
          <th><%= t.col_time %></th>
          <th><%= t.col_line %></th>
          <th><%= t.col_bus %></th>
          <th><%= t.col_from_to %></th>
        </tr>
      </thead>
      <tbody>
        <% let lastDate = ''; %>
        <% duties.forEach(d => { %>
          <tr<%= lastDate !== d.duty_date ? ' class="date-group-start"' : '' %>>
            <td>
              <% if (lastDate !== d.duty_date) { %>
                <%
                  lastDate = d.duty_date;
                  const dd = new Date(d.duty_date + 'T00:00:00');
                %>
                <span class="date-cell">
                  <%= dd.toLocaleDateString(t.date_locale, { weekday: 'short', day: '2-digit', month: '2-digit' }) %>
                </span>
              <% } %>
            </td>
            <td><%= d.driver_email %></td>
            <td class="nowrap"><%= d.start_time %>&thinsp;&ndash;&thinsp;<%= d.end_time %></td>
            <td><%= d.route || '—' %></td>
            <td><%= d.fleet_number || '—' %></td>
            <td><%= d.start_location %> &rarr; <%= d.end_location %></td>
          </tr>
          <% lastDate = d.duty_date; %>
        <% }); %>
      </tbody>
    </table>
  </div>
</div>
<%- include('../_footer') %>
