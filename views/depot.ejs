<%- include('_header', { title: 'Depot' }) %>
<div class="wide-wrap">
  <div class="page-header">
    <h1>Depot</h1>
    <div class="depot-legend">
      <span class="legend-item"><span class="legend-dot st-available"></span>Available</span>
      <span class="legend-item"><span class="legend-dot st-in_service"></span>In Service</span>
      <span class="legend-item"><span class="legend-dot st-maintenance"></span>Maintenance</span>
    </div>
  </div>

  <div class="depot-map">
    <% const rowNames = Object.keys(rows).sort(); %>
    <% rowNames.forEach(rowName => { %>
      <div class="depot-row-section">
        <div class="depot-row-label">Row <%= rowName %></div>
        <div class="depot-spots">
          <% rows[rowName].forEach(bus => { %>
            <div class="depot-spot st-<%= bus.status %>">
              <div class="spot-fleet"><%= bus.fleet_number %></div>
              <div class="spot-model"><%= bus.model %></div>
              <span class="status-badge st-<%= bus.status %>"><%= bus.status.replace('_', ' ') %></span>
              <% if (currentUser && currentUser.is_admin) { %>
                <form method="POST" action="/depot/<%= bus.id %>/status" class="spot-form">
                  <select name="status" onchange="this.form.submit()" class="spot-select">
                    <option value="available"   <%= bus.status === 'available'   ? 'selected' : '' %>>Available</option>
                    <option value="in_service"  <%= bus.status === 'in_service'  ? 'selected' : '' %>>In Service</option>
                    <option value="maintenance" <%= bus.status === 'maintenance' ? 'selected' : '' %>>Maintenance</option>
                  </select>
                </form>
              <% } %>
            </div>
          <% }); %>
        </div>
      </div>
    <% }); %>
  </div>

  <h2 class="section-heading">Fleet Overview</h2>
  <div class="table-wrap">
    <table class="admin-table">
      <thead>
        <tr>
          <th>Fleet No.</th>
          <th>Model</th>
          <th>Depot Location</th>
          <th>Status</th>
        </tr>
      </thead>
      <tbody>
        <% buses.forEach(bus => { %>
          <tr>
            <td><strong><%= bus.fleet_number %></strong></td>
            <td><%= bus.model %></td>
            <td>Row <%= bus.depot_row %>, Spot <%= bus.depot_spot %></td>
            <td><span class="status-badge st-<%= bus.status %>"><%= bus.status.replace('_', ' ') %></span></td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
</div>
<%- include('_footer') %>
